class Solution:
    def removeCoveredIntervals(self,intervals:List[List[int]])->int:
        c=0
        for i in range(len(intervals)):
            cover=False
            for j in range(len(intervals)):
                if i!=j:
                    if intervals[j][0]<=intervals[i][0] and intervals[j][1]>=intervals[i][1]:
                        cover=True
                        break
            if not cover:
                c+=1
        return c
