class Solution:
    def removeZeros(self, n: int) -> int:
        rev = 0

        while n > 0:
            temp = n % 10

            if temp != 0:
                rev = rev * 10 + temp

            n //= 10

        ans = 0

        while rev > 0:
            temp = rev % 10
            ans = ans * 10 + temp
            rev //= 10

        return ans
