from collections import Counter
class Solution:
    def frequencySort(self, nums: List[int]) -> List[int]:
        res=[]
        d=Counter(nums)
        new_list=sorted(d.items(),key=lambda x:(x[1],-x[0]))
        for key,value in new_list:
            for _ in range(value):
                res.append(key)
        return res
